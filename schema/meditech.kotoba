namespace meditech {

    entity Patient {
        id: string @unique
        id: string
        resourceType: string
        gender: string
        birthDate: string
        active: boolean
        deceasedBoolean: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Observation {
        id: string @unique
        id: string
        resourceType: string
        status: string
        effectiveDateTime: datetime
        valueString: string
        issued: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Encounter {
        id: string @unique
        id: string
        resourceType: string
        status: string
        serviceType: string
        period: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity MedicationRequest {
        id: string @unique
        id: string
        resourceType: string
        status: string
        intent: string
        authoredOn: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity AllergyIntolerance {
        id: string @unique
        id: string
        resourceType: string
        clinicalStatus: string
        criticality: string
        recordedDate: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Condition {
        id: string @unique
        id: string
        resourceType: string
        clinicalStatus: string
        recordedDate: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}
